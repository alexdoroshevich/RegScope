# FedComment Environment Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# === Required ===

# Regulations.gov API key (free, get from https://api.data.gov/signup/)
REGULATIONS_GOV_API_KEY=your_key_here

# OpenAI API key (for GPT-4o-mini via litellm)
OPENAI_API_KEY=sk-your_key_here

# === Optional (defaults shown) ===

# Data directory for Parquet files
FEDCOMMENT_DATA_DIR=./data/raw

# DuckDB database file path
FEDCOMMENT_DB_PATH=./data/fedcomment.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
FEDCOMMENT_LOG_LEVEL=INFO

# API server settings
FEDCOMMENT_API_HOST=0.0.0.0
FEDCOMMENT_API_PORT=8000
FEDCOMMENT_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# LLM settings (via litellm)
FEDCOMMENT_LLM_MODEL=gpt-4o-mini
FEDCOMMENT_LLM_MAX_TOKENS=500
FEDCOMMENT_LLM_TEMPERATURE=0.3

# Embedding model
FEDCOMMENT_EMBEDDING_MODEL=all-MiniLM-L6-v2
FEDCOMMENT_EMBEDDING_BATCH_SIZE=256
