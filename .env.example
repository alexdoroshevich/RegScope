# RegScope Environment Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# === Required ===

# Regulations.gov API key (free, get from https://api.data.gov/signup/)
REGULATIONS_GOV_API_KEY=your_key_here

# OpenAI API key (for GPT-4o-mini via litellm)
OPENAI_API_KEY=sk-your_key_here

# === Optional (defaults shown) ===

# Data directory for Parquet files
REGSCOPE_DATA_DIR=./data/raw

# DuckDB database file path
REGSCOPE_DB_PATH=./data/regscope.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
REGSCOPE_LOG_LEVEL=INFO

# API server settings
REGSCOPE_API_HOST=0.0.0.0
REGSCOPE_API_PORT=8000
REGSCOPE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# LLM settings (via litellm)
REGSCOPE_LLM_MODEL=gpt-4o-mini
REGSCOPE_LLM_MAX_TOKENS=500
REGSCOPE_LLM_TEMPERATURE=0.3

# Embedding model
REGSCOPE_EMBEDDING_MODEL=all-MiniLM-L6-v2
REGSCOPE_EMBEDDING_BATCH_SIZE=256
